  city            String?           // CityName
  type            String?           // Type
  fictionType     String?           // Fiction/ Non-Fiction

  rowHash         String?
  rawJson         Json
  createdAt       DateTime          @default(now())

  @@index([date])
  @@index([date, amount, qty, title])
  @@index([customerName])
  @@index([docNo])
  @@index([state, amount, inAmount, qty, inQty], map: "gsos_geo_state")
  @@index([city, state, amount, inAmount, qty, inQty], map: "gsos_geo_city")
  @@map("google_sheet_offline_sales")
}


# Environment variables for development
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/rajkamal_db?schema=public"

# Connection pool tuning — append to DATABASE_URL as query params
# connection_limit: max open connections per Prisma client (each client has its own pool)
# Note: two clients exist (main + sales), so total max = connection_limit * 2
# For Vercel/serverless with a managed DB pooler (Neon pooled, Supabase pooler): set to 1-3
# For direct connection (self-hosted Postgres): set to 10-20
DB_CONNECTION_LIMIT=20
DB_POOL_TIMEOUT=30
# To activate: append ?connection_limit=${DB_CONNECTION_LIMIT}&pool_timeout=${DB_POOL_TIMEOUT} to DATABASE_URL
# Example: DATABASE_URL="postgresql://user:pass@host:5432/db?connection_limit=20&pool_timeout=30"

# Slow query logging — queries slower than this threshold (ms) appear in logs
SLOW_QUERY_THRESHOLD_MS=500

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Fixed admin bootstrap (created at startup if no admin exists)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe_123!
ADMIN_NAME=Administrator

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# API Configuration
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FORMAT=combined
